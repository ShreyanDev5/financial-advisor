# Client/Advisor Public Information Settings
# These variables configure contact information shown across the portfolio site.
# Fallback values are set in the codebase to keep the app working out of the box.

# The full display name of the financial advisor
NEXT_PUBLIC_CLIENT_NAME="Monotosh Sardar"

# The first name used in conversational messages (e.g. WhatsApp templates)
NEXT_PUBLIC_CLIENT_FIRST_NAME="Monotosh"

# The advisor's contact number (spaces allowed, e.g. "98364 72260")
NEXT_PUBLIC_CLIENT_PHONE="98364 72260"

# The email address for advisory inquiries
NEXT_PUBLIC_CLIENT_EMAIL="moni22rick@gmail.com"

# The physical office address / location
NEXT_PUBLIC_CLIENT_ADDRESS="Budge Budge, Kolkata, West Bengal, India"
